datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Business {
  id              String          @id @default(uuid())
  name            String
  gstNumber       String?
  phone           String?
  address         String?
  workerSeatLimit Int             @default(5)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  users           User[]
  inventoryItems  InventoryItem[]
  notifications   Notification[]
  deliveries      Delivery[]
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  role         String    @default("STAFF") // "OWNER", "MANAGER", "STAFF", "DRIVER"
  isActive     Boolean   @default(true)
  joiningDate  DateTime  @default(now())
  lastLogin    DateTime?
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([businessId])
}

model InventoryItem {
  id                String             @id @default(uuid())
  materialName      String
  category          String
  sku               String
  unit              String
  quantity          Float              @default(0)
  reorderLevel      Float              @default(0)
  location          String
  costPrice         Float?
  sellingPrice      Float?
  businessId        String
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  stockTransactions StockTransaction[]

  @@index([businessId])
}

model StockTransaction {
  id              String        @id @default(uuid())
  type            String // "IN" or "OUT"
  quantity        Float
  note            String?
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  userId          String // User who made the adjustment
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
  @@index([userId])
}

model Notification {
  id         String   @id @default(uuid())
  title      String
  message    String
  isRead     Boolean  @default(false)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([businessId])
}

model Delivery {
  id              String          @id @default(uuid())
  deliveryNumber  String
  customerName    String
  customerPhone   String?
  deliveryAddress String
  materialName    String
  quantity        Float
  unit            String
  scheduledDate   DateTime?
  notes           String?
  status          String          @default("PENDING") // "PENDING", "OUT_FOR_DELIVERY", "DELIVERED"
  paymentStatus   String          @default("PENDING") // "PENDING", "RECEIVED"
  businessId      String
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([businessId])
}
