{
  "name": "construction-erp-backend",
  "version": "1.0.0",
  "description": "Backend MVP for Construction Material Supplier ERP",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "migrate": "prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "test:regression": "npx ts-node --files tests/run-regression-isolated.ts",
    "test:api": "npx ts-node --files tests/phase2b.smoke.ts",
    "test:phase391": "npx ts-node --files tests/phase391.supplier-payment-reversal.ts",
    "test:phase310": "npx ts-node --files tests/phase310.expense-management.ts",
    "test:phase311": "npx ts-node --files tests/phase311.reports-analytics.ts",
    "test:e2e": "npx ts-node --files tests/e2e-business-scenario.ts",
    "test:perf": "npx ts-node --files tests/performance-scale.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.30",
    "prisma": "5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.4.3"
  }
}